{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "open-code-war-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-09",
  // workers.dev URL 비활성 — opencodewar.dev 커스텀 도메인만 사용.
  "workers_dev": false,
  // 커스텀 도메인: opencodewar.dev → 이 Worker (DNS·인증서 자동 프로비저닝).
  "routes": [
    { "pattern": "opencodewar.dev", "custom_domain": true }
  ],
  // 리더보드 정적 웹을 같은 Worker에서 서빙(같은 도메인 → CORS 불필요).
  // 정적 에셋에 매칭 안 되는 경로(/health, /track, /leaderboard 등)는 Worker fetch로 폴백.
  // 루트(/)만 Worker를 먼저 태워 ?user= 프로필 공유 미리보기(OG 태그)를 동적으로 재작성한다.
  "assets": {
    "directory": "../web",
    "binding": "ASSETS",
    "run_worker_first": ["/"]
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  // 리더보드 스냅샷 신선도(ms). 운영 5분. 로컬 테스트는 .dev.vars로 낮춘다(예: 60000=1분).
  // RENDER_ORIGIN: 유저 OG 이미지를 온디맨드로 만드는 렌더 서비스(VPS) 오리진.
  //   미설정이면 /og/<pid>.png 는 KV 히트 or 공통 og.png 폴백만 한다. RENDER_KEY 는 secret.
  // GOOGLE_CLIENT_ID: Google OAuth 클라이언트 ID(공개값). secret 은 `wrangler secret put GOOGLE_CLIENT_SECRET`.
  // 미설정 시 /auth/* 는 "설정 안 됨" 안내만 반환한다(나머지 기능 정상).
  "vars": {
    "SNAPSHOT_TTL_MS": "300000",
    "RENDER_ORIGIN": "https://k1vw46e7a437td46o8wwibvi.185.143.228.89.sslip.io",
    "GOOGLE_CLIENT_ID": "456515525455-3kdm4vc7691ogjm476m2j9si0i28b6cf.apps.googleusercontent.com"
  },
  // 운영: 5분마다 스냅샷 재빌드. (로컬 dev는 자동 실행 안 됨 → 읽기 시 TTL 재빌드 또는 --test-scheduled)
  "triggers": {
    "crons": ["*/5 * * * *"]
  },
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "a04f93e331d7462faba81f94b806949d"
    }
  ],
  // /track 남용 방지: 클라이언트 IP당 60초 60건 상한(사람은 도달 불가, 스팸은 차단).
  // 집계는 Cloudflare 위치(colo)별 — 분산 공격은 위치 수만큼 완화. 추가 인프라 없이 Worker 네이티브.
  // period 는 10 또는 60만 허용. namespace_id 는 계정 내 rate-limiter 고유 정수.
  "ratelimits": [
    {
      "name": "TRACK_RATE_LIMITER",
      "namespace_id": "1001",
      "simple": { "limit": 60, "period": 60 }
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "ocw-db",
      "database_id": "340fb3b8-5a64-4fd5-8d11-8cd316ad8178",
      "migrations_dir": "migrations"
    }
  ]
}
